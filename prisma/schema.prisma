// schema.prisma (повний файл)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BodyType {
  HATCHBACK
  SEDAN
  WAGON
  SUV
  COUPE
  CONVERTIBLE
  VAN
  PICKUP
}

enum FuelType {
  PETROL
  DIESEL
  HYBRID
  PHEV
  ELECTRIC
  LPG
  CNG
}

enum GearboxType {
  MANUAL
  AUTOMATIC
}

model User {
  id          String   @id @default(cuid())
  firebaseUid String   @unique

  email       String?  @unique
  displayName String?
  phone       String?
  photoUrl    String?
  isAdmin     Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ratings     Rating[]
  comments    Comment[]
  listings    CarListing[]
}

model CarMake {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  models    CarModel[]
}

model CarModel {
  id        String   @id @default(cuid())
  makeId    String
  name      String
  slug      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  make      CarMake  @relation(fields: [makeId], references: [id], onDelete: Cascade)
  trims     CarTrim[]

  @@unique([makeId, slug])
  @@index([makeId])
}

model CarTrim {
  id           String       @id @default(cuid())
  modelId      String
  name         String
  yearFrom     Int?
  yearTo       Int?
  bodyType     BodyType?
  fuelType     FuelType?
  gearbox      GearboxType?
  powerHp      Int?
  engineCc     Int?
  rangeKm      Int?         // для електро
  basePricePln Int?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  model        CarModel     @relation(fields: [modelId], references: [id], onDelete: Cascade)
  ratings      Rating[]
  comments     Comment[]

  @@index([modelId])
}

model Rating {
  id        String   @id @default(cuid())
  userId    String
  trimId    String
  value     Int      // 1..5
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trim      CarTrim  @relation(fields: [trimId], references: [id], onDelete: Cascade)

  @@unique([userId, trimId])
  @@index([trimId])
  @@index([userId])
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  trimId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trim      CarTrim  @relation(fields: [trimId], references: [id], onDelete: Cascade)

  @@index([trimId])
  @@index([userId])
}

model CarListing {
  id          String   @id @default(cuid())
  userId      String?

  title       String
  description String?

  make        String
  model       String
  year        Int?
  mileageKm   Int?
  pricePln    Int?

  fuelType    FuelType?
  gearbox     GearboxType?
  bodyType    BodyType?

  city        String?
  phone       String?
  isActive    Boolean  @default(true)

  images      CarListingImage[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([make])
  @@index([model])
  @@index([isActive])
  @@index([pricePln])
  @@index([year])
  @@index([userId])
}

model CarListingImage {
  id        String   @id @default(cuid())
  listingId String
  url       String
  path      String?
  sortOrder Int      @default(0)

  createdAt DateTime @default(now())

  listing   CarListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([listingId, sortOrder])
}