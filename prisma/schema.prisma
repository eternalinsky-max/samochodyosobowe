// schema.prisma (повний файл)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BodyType {
  HATCHBACK
  SEDAN
  WAGON
  SUV
  COUPE
  CONVERTIBLE
  VAN
  PICKUP
}

enum FuelType {
  PETROL
  DIESEL
  HYBRID
  PHEV
  ELECTRIC
  LPG
  CNG
}

enum GearboxType {
  MANUAL
  AUTOMATIC
}

model User {
  id          String   @id @default(cuid())
  firebaseUid String   @unique

  email       String?  @unique
  displayName String?
  phone       String?
  photoUrl    String?
  isAdmin     Boolean  @default(false)

  // Рейтинг як продавця (агрегати)
  ratingWorkerCount      Int?
  ratingWorkerSum        Int?
  ratingWorkerAvg        Float?
  ratingWorkerBayesScore Float?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ratings         Rating[]
  comments        Comment[]
  listings        CarListing[]
  listingRatings  ListingRating[]
  ratingsGiven    SellerRating[] @relation("RatingGiven")
  ratingsReceived SellerRating[] @relation("RatingReceived")
  reviews         Review[]
}

model CarMake {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  models    CarModel[]
}

model CarModel {
  id        String   @id @default(cuid())
  makeId    String
  name      String
  slug      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  make      CarMake  @relation(fields: [makeId], references: [id], onDelete: Cascade)
  trims     CarTrim[]

  @@unique([makeId, slug])
  @@index([makeId])
}

model CarTrim {
  id           String       @id @default(cuid())
  modelId      String
  name         String
  yearFrom     Int?
  yearTo       Int?
  bodyType     BodyType?
  fuelType     FuelType?
  gearbox      GearboxType?
  powerHp      Int?
  engineCc     Int?
  rangeKm      Int?
  basePricePln Int?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  model        CarModel     @relation(fields: [modelId], references: [id], onDelete: Cascade)
  ratings      Rating[]
  comments     Comment[]

  @@index([modelId])
}

model Rating {
  id        String   @id @default(cuid())
  userId    String
  trimId    String
  value     Int      // 1..5
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trim      CarTrim  @relation(fields: [trimId], references: [id], onDelete: Cascade)

  @@unique([userId, trimId])
  @@index([trimId])
  @@index([userId])
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  trimId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trim      CarTrim  @relation(fields: [trimId], references: [id], onDelete: Cascade)

  @@index([trimId])
  @@index([userId])
}

model CarListing {
  id          String   @id @default(cuid())
  userId      String?

  title       String
  description String?

  make        String
  model       String
  year        Int?
  mileageKm   Int?
  pricePln    Int?

  fuelType    FuelType?
  gearbox     GearboxType?
  bodyType    BodyType?

  city        String?
  phone       String?
  isActive    Boolean  @default(true)
  isDraft     Boolean  @default(false)

  images      CarListingImage[]
  ratings     ListingRating[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([make])
  @@index([model])
  @@index([isActive])
  @@index([pricePln])
  @@index([year])
  @@index([userId])
}

model CarListingImage {
  id        String   @id @default(cuid())
  listingId String
  url       String
  path      String?
  sortOrder Int      @default(0)

  createdAt DateTime @default(now())

  listing   CarListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([listingId, sortOrder])
}

model ListingRating {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  value     Int      // 1..5
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   CarListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([listingId])
  @@index([userId])
}

model SellerRating {
  id         String   @id @default(cuid())
  fromUserId String
  toUserId   String
  value      Int      // 1..5
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  fromUser   User     @relation("RatingGiven", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser     User     @relation("RatingReceived", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
  @@index([toUserId])
  @@index([fromUserId])
}

model Review {
  id            String   @id @default(cuid())
  authorId      String
  targetType    String   // "LISTING" | "USER"
  targetId      String
  ratingOverall Int      // 1..5
  text          String   @default("")
  isHidden      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  User          User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([authorId, targetType, targetId])
  @@index([targetType, targetId])
  @@index([authorId])
}
